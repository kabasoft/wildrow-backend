# --- Server ---
NODE_ENV=development
PORT=8080
CORS_ORIGINS=http://localhost:5173

# --- Database (Cloud SQL for Postgres in prod, local container in dev) ---
DATABASE_URL=postgresql://wildrow:wildrow_dev@localhost:5432/wildrow?schema=public

# --- Auth ---
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m

# --- MNO gateway / webhook signing (shared secret with aggregator) ---
MNO_HMAC_SECRET=change-me
MNO_MOCK_LATENCY_MS=1200

# --- Custodian bank SFTP (production: pulled from Secret Manager, not env) ---
CUSTODIAN_SFTP_HOST=sftp.custodian-trust.zm
CUSTODIAN_SFTP_PATH=/secure/reconciliation/wildrow_trust/
CUSTODIAN_MIN_LIQUIDITY_PCT=0.15

# --- Ledger / NAV engine assumptions (Annex E) ---
LEDGER_GROSS_APY=0.12
LEDGER_MGMT_FEE_APY=0.02
LEDGER_NET_APY=0.10
